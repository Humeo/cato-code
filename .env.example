# ─────────────────────────────────────────────────────────────────────────────
# CatoCode Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI (required) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://...    # Custom API endpoint (e.g. proxy). Omit to use Anthropic directly.

# ── GitHub Auth (required — choose one) ──────────────────────────────────────
# Option A: Personal Access Token (CLI mode — simplest, single-user)
# Create at: https://github.com/settings/tokens → Fine-grained or Classic
# Required scopes: repo, issues, pull_requests
GITHUB_TOKEN=ghp_...

# Option B: GitHub App (SaaS mode — multi-user, org-wide)
# See docs/GITHUB_APP_SETUP.md for setup instructions
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# GITHUB_APP_WEBHOOK_SECRET=your-random-webhook-secret   # openssl rand -hex 32
# GITHUB_APP_NAME=catocode-bot
# GITHUB_APP_INSTALLATION_ID=789   # Only needed for single-installation App auth

# ── GitHub OAuth (SaaS mode only — for user login) ──────────────────────────
# GITHUB_OAUTH_CLIENT_ID=Ov23li...
# GITHUB_OAUTH_CLIENT_SECRET=your-oauth-secret

# ── Session / Encryption (SaaS mode only) ───────────────────────────────────
# SESSION_SECRET_KEY=your-64-char-hex-string   # openssl rand -hex 32

# ── URLs ─────────────────────────────────────────────────────────────────────
CATOCODE_BASE_URL=http://localhost:8000        # Backend URL (no trailing slash)
FRONTEND_URL=http://localhost:3000             # Frontend URL for CORS

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — fine for single-user / small teams)
# In Docker: stored at /data/catocode.db (persisted via volume)
# Local: stored at ~/.catocode/catocode.db
#
# PostgreSQL (optional — recommended for multi-user production)
# DATABASE_URL=postgresql://catocode:password@localhost:5432/catocode

# ── Git identity (for commits made inside the worker container) ──────────────
GIT_USER_NAME=CatoCode
GIT_USER_EMAIL=catocode@bot.local

# ── Tuning ───────────────────────────────────────────────────────────────────
MAX_CONCURRENT=3                               # Max concurrent activities
CATOCODE_PATROL_MAX_ISSUES=5                   # Max issues to create per patrol window
CATOCODE_PATROL_WINDOW_HOURS=12                # Rolling window for patrol
CATOCODE_MEM=8g                                # Memory limit for worker container
CATOCODE_CPUS=4                                # CPU limit for worker container

# ── Embedding / RAG dedup (optional) ─────────────────────────────────────────
# Powers patrol issue deduplication. If unset, dedup is disabled gracefully.
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-large
